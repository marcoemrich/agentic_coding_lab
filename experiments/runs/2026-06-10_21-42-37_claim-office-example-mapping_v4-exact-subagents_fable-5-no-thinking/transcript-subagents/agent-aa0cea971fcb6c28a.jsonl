,\n39\t      ],\n40\t    };\n41\t\n42\t    const result = runCli(JSON.stringify(scenario));\n43\t\n44\t    expect(result.status).toBe(0);\n45\t    expect(JSON.parse(result.stdout)).toEqual(processScenario(scenario));\n46\t  });\n47\t  it.todo(\n48\t    \"should exit non-zero with an error description on stderr and no results on stdout for an unknown item type\",\n49\t  );\n50\t});\n51\t"}]},"uuid":"f6cd40eb-0de9-461f-a9ac-491decbb236e","timestamp":"2026-06-10T23:34:17.087Z","sourceToolAssistantUUID":"93da141e-730c-4c76-bb94-cdc33fa12081","userType":"external","entrypoint":"sdk-cli","cwd":"/home/experimenter/experiments/runs/2026-06-10_21-42-37_claim-office-example-mapping_v4-exact-subagents_fable-5-no-thinking","sessionId":"71e47306-4fbd-4c08-97c6-5346843a7995","version":"2.1.170","gitBranch":"HEAD"}
