export function quote(customer: any, items: any[]) {
  const allItemsAreRunes = items.every(item => item.type === "rune");
  const processingFee = 5;
  
  // Handle 2 runes case: 50 G base + 5 G processing fee = 55 G
  if (items.length === 2 && allItemsAreRunes) {
    const basePremium = 50; // 2 × 25 G per rune
    return { premium: basePremium + processingFee };
  }
  
  // Handle 3 runes case (block rate): 60 G base + 5 G processing fee = 65 G
  if (items.length === 3 && allItemsAreRunes) {
    const basePremium = 60; // Special block rate
    return { premium: basePremium + processingFee };
  }
  
  return { premium: 0 };
}

Component Count:
- Constants: 6 ("rune", 5(2), 2, 3, 50, 60, 0) = 6
- Bindings: 7 (customer, items(2), item(2), allItemsAreRunes, processingFee, basePremium(2)) = 7
- Invocations: 2 (every(1), +(2)) = 4
- Conditionals: 2 (if statements) = 8
- Loops: 0 = 0
- Assignments: 3 (const assignments) = 18

Total Mass: 43

Mass Change: 22 -> 43 (delta +21)
