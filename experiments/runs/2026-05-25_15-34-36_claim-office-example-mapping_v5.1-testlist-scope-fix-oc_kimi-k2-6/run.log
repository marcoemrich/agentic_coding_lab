const BASE_PREMIUMS = { sword: 100, amulet: 60, staff: 80, potion: 40, rune: 25, moonstone: 25 };
function quote(customer, items, previousQuotes = 0) {
  if (items.length === 0) return 5;
  let policyBase = 0;
  for (const item of items) {
    const itemBase = BASE_PREMIUMS[item.type] || 0;
    let itemPremium = itemBase;
    if (item.cursed) itemPremium += itemBase * 0.5;
    if (item.enchantment >= 5) itemPremium += itemBase * 0.3;
    policyBase += itemPremium;
  }
  if (customer.yearsWithMHPCO >= 2) policyBase *= 0.8;
  policyBase *= 1.1;
  if (previousQuotes > 0) policyBase *= 0.85;
  return Math.ceil(policyBase) + 5;
}
