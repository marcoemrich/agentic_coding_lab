ount: 200 }],\n56\t            },\n57\t          },\n58\t        ],\n59\t      };\n60\t\n61\t      const { stdout, exitCode } = await runCli(JSON.stringify(scenario));\n62\t\n63\t      expect(JSON.parse(stdout)).toEqual({\n64\t        results: [{ premium: 59 }, { payout: 100, remainingCap: 1100 }],\n65\t      });\n66\t      expect(exitCode).toBe(0);\n67\t    },\n68\t    20000\n69\t  );\n70\t  it(\n71\t    \"should exit with a non-zero code, write an error description to stderr, and write no results to stdout for an unknown item type\",\n72\t    async () => {\n73\t      const scenario = {\n74\t        customer: { yearsWithMHPCO: 0 },\n75\t        steps: [{ op: \"quote\", items: [{ type: \"broomstick\" }] }],\n76\t      };\n77\t\n78\t      const { stdout, stderr, exitCode } = await runCli(\n79\t        JSON.stringify(scenario)\n80\t      );\n81\t\n82\t      expect(exitCode).not.toBe(0);\n83\t      expect(stderr).toContain(\"Unknown item type\");\n84\t      expect(stdout).toBe(\"\");\n85\t    },\n86\t    20000\n87\t  );\n88\t});\n89\t"}]},"uuid":"701e1bff-2b65-4637-8c0e-87027b0ef8db","timestamp":"2026-06-10T05:01:37.246Z","sourceToolAssistantUUID":"6c9ce195-ead7-4ef3-90a9-751964ae5d79","userType":"external","entrypoint":"sdk-cli","cwd":"/home/experimenter/experiments/runs/2026-06-10_03-09-21_claim-office-example-mapping_v4-exact-subagents_fable-5-no-thinking","sessionId":"309d160d-abaf-4b97-9cca-3921ea170db5","version":"2.1.170","gitBranch":"HEAD"}
