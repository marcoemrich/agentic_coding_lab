ount: 200 }],\n56\t            },\n57\t          },\n58\t        ],\n59\t      };\n60\t\n61\t      const { stdout, exitCode } = await runCli(JSON.stringify(scenario));\n62\t\n63\t      expect(JSON.parse(stdout)).toEqual({\n64\t        results: [{ premium: 59 }, { payout: 100, remainingCap: 1100 }],\n65\t      });\n66\t      expect(exitCode).toBe(0);\n67\t    },\n68\t    20000\n69\t  );\n70\t  it.todo(\n71\t    \"should exit with a non-zero code, write an error description to stderr, and write no results to stdout for an unknown item type\"\n72\t  );\n73\t});\n74\t"}]},"uuid":"5b49197a-bc6d-4644-af51-3d591690a049","timestamp":"2026-06-10T05:00:26.687Z","sourceToolAssistantUUID":"ec8db289-2d5f-4865-8bd6-739188942885","userType":"external","entrypoint":"sdk-cli","cwd":"/home/experimenter/experiments/runs/2026-06-10_03-09-21_claim-office-example-mapping_v4-exact-subagents_fable-5-no-thinking","sessionId":"309d160d-abaf-4b97-9cca-3921ea170db5","version":"2.1.170","gitBranch":"HEAD"}
