+): { payout: number; remainingCap: number } {
+  let totalPayout = 0;
+
+  for (const damage of damages) {
+    const item = policy.items.find((i) => i.type === damage.itemType);
+    if (!item) {
+      throw new Error(`Item ${damage.itemType} not found in policy`);
