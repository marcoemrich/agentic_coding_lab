should cap total payout at 2x unmodified insurance sum across multiple claim events\");\n57\t  it.todo(\"should round payout DOWN to whole G in MHPCO's favor\");\n58\t\n59\t  // === CLI integration / error cases ===\n60\t  it.todo(\"should exit non-zero and write to stderr when quote contains an unknown item type\");\n61\t  it.todo(\"should exit non-zero when a claim references an item not in the policy\");\n62\t  it.todo(\"should exit non-zero when a claim has more damage entries of a type than the policy covers\");\n63\t  it.todo(\"should exit non-zero when a claim contains a negative damage amount\");\n64\t});\n65\t"}]},"uuid":"10afde64-0438-41d7-90c3-de13e1637ba5","timestamp":"2026-05-15T04:47:29.018Z","sourceToolAssistantUUID":"428dfe22-4e3b-40f3-a34e-b7dfe8ad317c","userType":"external","entrypoint":"sdk-cli","cwd":"/home/experimenter/experiments/runs/2026-05-15_04-46-00_claim-office-example-mapping_v4-exact-subagents_opus-4-7-no-thinking","sessionId":"78eba7d6-0fe4-41f1-9cc2-95a9cf61f8c7","version":"2.1.107","gitBranch":"HEAD","slug":"breezy-giggling-swing"}
