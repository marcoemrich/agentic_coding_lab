const BASE_PREMIUMS = {sword: 100, amulet: 60, staff: 80, potion: 40, rune: 25, moonstone: 25};

function calculatePremium(params) {
  const items = params.items;
  const customer = params.customer;
  const quoteCount = params.quoteCount;
  
  if (items.length === 0) return 5;
  
  let totalBasePremium = 0;
  for (const item of items) {
    let premium = BASE_PREMIUMS[item.type] || 0;
    if (item.cursed) premium *= 1.5;
    if (item.enchantment !== undefined && item.enchantment >= 5) premium *= 1.3;
    totalBasePremium += premium;
  }
  
  const runeCount = items.filter(i => i.type === 'rune').length;
  const moonstoneCount = items.filter(i => i.type === 'moonstone').length;
  const runeBlocks = Math.floor(runeCount / 3);
  const moonstoneBlocks = Math.floor(moonstoneCount / 3);
  const blockDiscount = runeBlocks * 15 + moonstoneBlocks * 15;
  totalBasePremium -= blockDiscount;
  
  if (quoteCount === 0) {
    totalBasePremium *= 1.1;
  } else {
    totalBasePremium = totalBasePremium * 0.85 * 1.1;
  }
  
  if (customer.yearsWithMHPCO >= 2) {
    totalBasePremium *= 0.8;
  }
  
  totalBasePremium += 5;
  return Math.ceil(totalBasePremium);
}

console.log('sword:', calculatePremium({items: [{type: 'sword'}], customer: {yearsWithMHPCO: 0}, quoteCount: 0}));
console.log('3 runes:', calculatePremium({items: [{type: 'rune'}, {type: 'rune'}, {type: 'rune'}], customer: {yearsWithMHPCO: 0}, quoteCount: 0}));
console.log('4 runes:', calculatePremium({items: [{type: 'rune'}, {type: 'rune'}, {type: 'rune'}, {type: 'rune'}], customer: {yearsWithMHPCO: 0}, quoteCount: 0}));
console.log('7 runes:', calculatePremium({items: [{type: 'rune'}, {type: 'rune'}, {type: 'rune'}, {type: 'rune'}, {type: 'rune'}, {type: 'rune'}, {type: 'rune'}], customer: {yearsWithMHPCO: 0}, quoteCount: 0}));
console.log('2 runes + 1 moonstone:', calculatePremium({items: [{type: 'rune'}, {type: 'rune'}, {type: 'moonstone'}], customer: {yearsWithMHPCO: 0}, quoteCount: 0}));
console.log('3 runes + 3 moonstones:', calculatePremium({items: [{type: 'rune'}, {type: 'rune'}, {type: 'rune'}, {type: 'moonstone'}, {type: 'moonstone'}, {type: 'moonstone'}], customer: {yearsWithMHPCO: 0}, quoteCount: 0}));
console.log('cursed sword:', calculatePremium({items: [{type: 'sword', cursed: true}], customer: {yearsWithMHPCO: 0}, quoteCount: 0}));
console.log('sword ench5:', calculatePremium({items: [{type: 'sword', enchantment: 5}], customer: {yearsWithMHPCO: 0}, quoteCount: 0}));
console.log('sword years>=2:', calculatePremium({items: [{type: 'sword'}], customer: {yearsWithMHPCO: 2}, quoteCount: 0}));
console.log('sword quoteCount=1:', calculatePremium({items: [{type: 'sword'}], customer: {yearsWithMHPCO: 0}, quoteCount: 1}));
console.log('cursed sword ench7 quote1:', calculatePremium({items: [{type: 'sword', cursed: true, enchantment: 7}], customer: {yearsWithMHPCO: 3}, quoteCount: 1}));
