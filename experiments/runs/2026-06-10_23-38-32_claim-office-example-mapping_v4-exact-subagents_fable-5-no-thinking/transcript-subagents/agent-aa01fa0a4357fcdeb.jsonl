ion to stderr for an invalid scenario\", () => {\n54\t    const result = runCli(invalidScenario);\n55\t\n56\t    expect(result.stderr).toContain(\"broomstick\");\n57\t  }, 30_000);\n58\t  it.todo(\"should not write results to stdout for an invalid scenario\");\n59\t  // NOT: premium/payout business rules (covered in claim-office.spec.ts),\n60\t  // malformed/non-JSON stdin handling, CLI flags, output formatting options\n61\t});\n62\t"}]},"uuid":"5b2433ca-ba6f-4c99-89e4-536dd59dc933","timestamp":"2026-06-11T03:01:54.926Z","sourceToolAssistantUUID":"2b44b720-2667-4fd3-87b7-d1df3a8891ab","userType":"external","entrypoint":"sdk-cli","cwd":"/home/experimenter/experiments/runs/2026-06-10_23-38-32_claim-office-example-mapping_v4-exact-subagents_fable-5-no-thinking","sessionId":"b62affb8-34b7-4a84-b13c-b6afe925d6e4","version":"2.1.170","gitBranch":"HEAD"}
