# TDD Experiment Environment Configuration
# Copy this to .env and fill in your values

# ═══════════════════════════════════════════════════════════
# Option A: Direct Anthropic API Key
# ═══════════════════════════════════════════════════════════
# ANTHROPIC_API_KEY=sk-ant-...

# Option A2: Path to file containing key
# ANTHROPIC_API_KEY_FILE=~/.anthropic/api_key

# ═══════════════════════════════════════════════════════════
# Option B: Portkey Gateway (or other proxy)
# ═══════════════════════════════════════════════════════════
# ANTHROPIC_BASE_URL=https://api.portkey.ai
# ANTHROPIC_AUTH_TOKEN=dummy
# ANTHROPIC_CUSTOM_HEADERS=x-portkey-api-key: your-portkey-key
# ANTHROPIC_DEFAULT_SONNET_MODEL=@vertex-ai/anthropic.claude-sonnet-4-6
# ANTHROPIC_DEFAULT_HAIKU_MODEL=@vertex-ai/anthropic.claude-haiku-4-5@20251001
# ANTHROPIC_DEFAULT_OPUS_MODEL=@vertex-eu-global/anthropic.claude-opus-4-7
# CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS=1

# Portkey key for OpenCode harness (uses different auth scheme than CC).
# Referenced from opencode.json via {env:PORTKEY_API_KEY}. Same key as
# the one in ANTHROPIC_CUSTOM_HEADERS above (Portkey key, not provider key).
# PORTKEY_API_KEY=your-portkey-key

# Separate Portkey key for the Mistral workspace (Mistral virtual key not
# configured in the eval workspace). Referenced from opencode.json's
# `portkey-mistral` provider block. Only needed when the batch plan includes
# the `mistral-medium-3-5` model.
# PORTKEY_MISTRAL_API_KEY=your-portkey-mistral-workspace-key

# Separate Portkey key for the "cc" workspace hosting coding-focused models
# (Mistral Devstral/Codestral via @mistral/* and Bedrock Qwen3-Coder via
# @bedrock-eu-north-1/*). Referenced from opencode.json's `portkey-cc`
# provider block. Required for the RQ-model-novel-oc fill models
# devstral-medium-2507, devstral-2512, codestral-2508, qwen3-coder-480b.
# PORTKEY_CC_API_KEY=your-portkey-cc-workspace-key

# OpenRouter is reached via the @openrouter-eval/ integration prefix in
# the model id (Portkey holds OpenRouter creds server-side per integration).
# No separate OPENROUTER_API_KEY needed.

# ═══════════════════════════════════════════════════════════
# Common Settings
# ═══════════════════════════════════════════════════════════
# Extended Thinking (optional, defaults to true)
# Set to false to disable extended thinking (sets MAX_THINKING_TOKENS=0)
# Note: Batch runner overrides this per-run to test all 4 model configs
CLAUDE_THINKING=true

# Claude config directory (optional)
# CLAUDE_CONFIG_DIR=~/.claude

# ═══════════════════════════════════════════════════════════
# Container User (fixes volume permission issues)
# ═══════════════════════════════════════════════════════════
# Run `id -u` and `id -g` to get your values
USER_ID=1000
GROUP_ID=1000
