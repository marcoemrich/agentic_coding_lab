__pycache__/
node_modules/
experiments/runs/*/coverage/
experiments/runs/*/pnpm-lock.yaml
experiments/runs/.pnpm-store/
# Stryker mutation-testing scaffolding (regenerated per run by
# experiments/compute-mutation-score.py). Same status as coverage/.
experiments/runs/*/.npmrc
experiments/runs/*/stryker.config.json
experiments/runs/*/stryker.log
experiments/runs/*/reports/
experiments/reanalyze.log
.claude/scheduled_tasks.lock
.claude/settings.local.json
experiments/batch-plans/*.shard*.json
# Batch fill plans are temporary snapshots — recomputable from RQ READMEs
# via batch-plan-from-rq.py. Only the smoke-test plan stays tracked.
experiments/batch-plans/*-fill*.json
experiments/batch-plans/rq-*.json
nohup.out
