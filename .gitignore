__pycache__/
node_modules/
experiments/runs/*/coverage/
experiments/runs/*/pnpm-lock.yaml
experiments/runs/.pnpm-store/
# Stryker mutation-testing scaffolding (regenerated per run by
# experiments/compute-mutation-score.py). Same status as coverage/.
experiments/runs/*/.npmrc
experiments/runs/*/stryker.config.json
experiments/runs/*/stryker.log
experiments/runs/*/reports/
experiments/reanalyze.log
.claude/scheduled_tasks.lock
.claude/settings.local.json
# Container-Cleanup-Timestamp wird bei jedem Batch refresht.
experiments/docker/claude-config/.last-cleanup
# Batch plans: ignore all by default — most are ad-hoc / generated /
# referencing archived workflows. Only the basic smoke-test plan stays
# tracked. New permanent plans need an explicit !-line here.
experiments/batch-plans/*.json
!experiments/batch-plans/smoke-test.json
!experiments/batch-plans/skeleton-oc.json
!experiments/batch-plans/skeleton-v5-oc.json
nohup.out
